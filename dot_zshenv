# ⚠️ DO NOT CHANGE THIS FILE!
# If you need to edit, execute "chezmoi edit ~/.config/zsh/.zshenv"

# If you need to override .zshenv for local,
# you can create a .zshenv.local in $HOME/.config/zsh/

# Set ZSH config files directory
export ZDOTDIR=$HOME/.config/zsh

# Load .zshenv.local if available
[ -f "$ZDOTDIR/.zshenv.local" ] && source "$ZDOTDIR/.zshenv.local"
